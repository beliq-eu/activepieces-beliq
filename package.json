{
  "name": "activepieces-beliq",
  "version": "0.1.1",
  "description": "beliq connector for Activepieces: generate, validate, parse, and convert EU-compliant e-invoices (XRechnung, ZUGFeRD, Factur-X, Peppol BIS).",
  "keywords": [
    "activepieces",
    "activepieces-piece",
    "beliq",
    "e-invoice",
    "einvoice",
    "xrechnung",
    "zugferd",
    "factur-x",
    "peppol",
    "en16931",
    "compliance"
  ],
  "license": "MIT",
  "homepage": "https://beliq.eu",
  "author": "beliq <hello@beliq.eu>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beliq-eu/activepieces-beliq.git"
  },
  "main": "./dist/src/index.js",
  "engines": {
    "node": ">=18.20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.lib.json && node scripts/prepare-dist.mjs",
    "prepublishOnly": "npm run build",
    "dev": "tsc -p tsconfig.lib.json --watch",
    "lint": "eslint src",
    "lintfix": "eslint src --fix",
    "test": "vitest run test/connector.test.ts",
    "test:integration": "vitest run test/integration.test.ts",
    "scrub:check": "grep -rn $'\\u2014' src README.md examples && echo 'em-dash found' && exit 1 || echo 'no em-dash'"
  },
  "dependencies": {
    "@activepieces/pieces-common": "0.12.5",
    "@activepieces/pieces-framework": "0.32.0",
    "@activepieces/shared": "0.96.2",
    "@beliq/sdk": "^0.1.1",
    "tslib": "^2.6.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.8"
  }
}
